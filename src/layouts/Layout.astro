---
import Analytics from "@vercel/analytics/astro";
import "@fontsource-variable/inter";
import "@fontsource-variable/playfair-display";
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta property="og:url" content="https://jacobldraws.vercel.app" />
        <meta property="og:image" content="/banner_image.jpeg" />
        <meta charset="UTF-8" />
        <meta name="description" content="View Jacob's art or contact him for work!" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <Analytics />
    </head>
    <body class="bg-secondary text-primary dark:bg-secondary-dark dark:text-primary-dark">
        <nav
            class="text-md lg:h-68 sticky top-0 z-50 flex w-full items-center justify-start gap-6 border-b-[1px] border-primary bg-inherit px-2 py-1 text-left underline-offset-4 sm:gap-8 sm:py-2 sm:text-xl lg:fixed lg:mx-4 lg:my-auto lg:mt-16 lg:w-36 lg:flex-col lg:items-start lg:justify-normal lg:border-b-0 lg:py-0 dark:border-primary-dark">
            <a href="/" class="font-serif font-bold hover:underline">JacobLDraws</a>
            <a href="/art" class="font-serif hover:underline">ART</a>
            <a href="/writing" class="font-serif hover:underline">WRITING</a>
            <a href="/books" class="hidden font-serif hover:underline sm:block">BOOKS</a>
            <a href="/directory" class="hidden font-serif hover:underline sm:block">DIRECTORY</a>
            <!-- <a href="/projects" class="font-serif font-medium hover:underline">projects</a> -->
            <a
                href="https://www.instagram.com/jacobldraws/"
                target="_blank"
                class="lg:mx-auto dark:hidden"
                ><img src="/Instagram_Glyph_Black.svg" width="20" /></a
            >
            <a
                href="https://www.instagram.com/jacobldraws/"
                target="_blank"
                class="hidden lg:mx-auto dark:block"
                ><img src="/Instagram_Glyph_White.svg" width="20" /></a
            >
        </nav>

        {
            (() => {
                const path = Astro.url.pathname;
                const useAlt = path === "/" || path === "/writing" || path === "/art";
                if (useAlt) {
                    return (
                        <div class="ml-auto mt-0 lg:w-5/6 lg:pr-4">
                            <slot />
                        </div>
                    );
                } else {
                    return (
                        <div class="mx-auto mt-0 lg:w-2/3">
                            <slot />
                        </div>
                    );
                }
            })()
        }
    </body>
</html>
