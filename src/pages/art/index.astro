---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { RegularMasonryGrid as MasonryGrid, Frame } from '@masonry-grid/react'
import ArtMasonryGrid from "../../components/ArtMasonryGrid.tsx";


// grab every image file under assets/art
const imageModules = import.meta.glob<ImageMetadata>("../../assets/art/*.{png,jpg,jpeg}", { eager: true, import: "default"  });
const images: any = Object.values(imageModules);

---

<Layout title="Art">
    <main class="mx-auto mt-8 w-11/12 sm:mx-0 sm:w-full sm:px-4">
        <ArtMasonryGrid artEntries={images} client:load/>
    </main>
    <script type="module" src="/scripts/imageZoom.js" defer></script>
</Layout>
