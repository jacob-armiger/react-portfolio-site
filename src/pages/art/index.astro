---
import Layout from "../../layouts/Layout.astro";
import { getImage } from "astro:assets";
import ArtMasonryGrid from "../../components/ArtMasonryGrid.tsx";
import type { OptimizedImage } from "../../components/ArtMasonryGrid.tsx";

type RawModule = { default: ImageMetadata };

async function loadCategory(pattern: string, label: string): Promise<OptimizedImage[]> {
    const modules = import.meta.glob<RawModule>([
        "../../assets/selectedWork/*.{png,jpg,jpeg}",
        "../../assets/digitalStudies/*.{png,jpg,jpeg}",
        "../../assets/drawings/*.{png,jpg,jpeg}",
        "../../assets/oilPaintings/*.{png,jpg,jpeg}",
    ], { eager: true });

    const raw = Object.entries(modules)
        .filter(([path]) => path.includes(`/${pattern}/`))
        .map(([, m]) => m.default);

    return Promise.all(
        raw.map(async (img) => {
            const optimized = await getImage({ src: img, format: "webp", width: 560 });
            return {
                src: optimized.src,
                width: (optimized.attributes.width as number) ?? img.width,
                height: (optimized.attributes.height as number) ?? img.height,
                originalSrc: img.src,
                category: label,
            };
        })
    );
}

const images: OptimizedImage[] = [
    ...await loadCategory("selectedWork", "Selected Work"),
    ...await loadCategory("drawings", "Drawings"),
    ...await loadCategory("oilPaintings", "Oil Paintings"),
    ...await loadCategory("digitalStudies", "Digital Studies"),
];
---

<Layout title="Art">
    <main class="lg:col-span-10 lg:col-start-3 col-span-12 px-0 sm:px-6 lg:px-0 pt-6 lg:pt-8">
        <ArtMasonryGrid artEntries={images} client:only="react"/>
    </main>
    <script type="module" src="/scripts/imageZoom.js" defer></script>
</Layout>
