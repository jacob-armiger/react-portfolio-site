---
import Layout from "../../layouts/Layout.astro";
import { getImage } from "astro:assets";
import ArtMasonryGrid from "../../components/ArtMasonryGrid.tsx";
import type { OptimizedImage } from "../../components/ArtMasonryGrid.tsx";

type RawModule = { default: ImageMetadata };

const CATEGORY_ORDER: Array<[string, string]> = [
    ['selectedWork', 'Selected Work'],
    ['drawings', 'Drawings'],
    ['oilPaintings', 'Oil Paintings'],
    ['digitalStudies', 'Digital Studies'],
];

// Single glob call — module map is built once and grouped by folder
const allModules = import.meta.glob<RawModule>([
    "../../assets/selectedWork/*.{png,jpg,jpeg}",
    "../../assets/digitalStudies/*.{png,jpg,jpeg}",
    "../../assets/drawings/*.{png,jpg,jpeg}",
    "../../assets/oilPaintings/*.{png,jpg,jpeg}",
], { eager: true });

const grouped = new Map<string, RawModule[]>();
for (const [path, mod] of Object.entries(allModules)) {
    const folder = path.split('/').at(-2)!;
    const list = grouped.get(folder) ?? [];
    list.push(mod);
    grouped.set(folder, list);
}

const images: OptimizedImage[] = await Promise.all(
    CATEGORY_ORDER.flatMap(([folder, label]) =>
        (grouped.get(folder) ?? []).map(async (m) => {
            const img = m.default;
            const optimized = await getImage({ src: img, format: "webp", width: 560 });
            return {
                src: optimized.src,
                width: (optimized.attributes.width as number) ?? img.width,
                height: (optimized.attributes.height as number) ?? img.height,
                originalSrc: img.src,
                category: label,
            };
        })
    )
);
---

<Layout title="Art">
    <main class="lg:col-span-10 lg:col-start-3 col-span-12 px-0 sm:px-6 lg:px-0 pt-6 lg:pt-8">
        <ArtMasonryGrid artEntries={images} client:only="react"/>
    </main>
    <script is:inline type="module" src="/scripts/imageZoom.js" defer></script>
</Layout>
