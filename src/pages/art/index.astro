---
import Layout from "../../layouts/Layout.astro";
import { getImage } from "astro:assets";
import ArtMasonryGrid from "../../components/ArtMasonryGrid.tsx";
import RssFeedButton from "../../components/RssFeedButton.astro";
import type { OptimizedImage } from "../../components/ArtMasonryGrid.tsx";

type RawModule = { default: ImageMetadata };
type GroupedEntry = { path: string; mod: RawModule };

const CATEGORY_ORDER: Array<[string, string]> = [
    ['selectedWork', 'Selected Work'],
    ['drawings', 'Drawings'],
    ['oilPaintings', 'Oil Paintings'],
    ['digitalStudies', 'Digital Studies'],
];

// Single glob call — module map is built once and grouped by folder
const allModules = import.meta.glob<RawModule>([
    "../../assets/selectedWork/*.{png,jpg,jpeg}",
    "../../assets/digitalStudies/*.{png,jpg,jpeg}",
    "../../assets/drawings/*.{png,jpg,jpeg}",
    "../../assets/oilPaintings/*.{png,jpg,jpeg}",
], { eager: true });

const getFileNameFromPath = (path: string) =>
    path.split('/').at(-1)?.toLowerCase() ?? '';

// Sort once by source path filename so deploy-time hashed asset URLs cannot affect order.
const sortedEntries: GroupedEntry[] = Object.entries(allModules)
    .map(([path, mod]) => ({ path, mod }))
    .sort((a, b) => {
        const nameDiff = getFileNameFromPath(b.path).localeCompare(
            getFileNameFromPath(a.path),
            undefined,
            { numeric: true, sensitivity: 'base' }
        );
        if (nameDiff !== 0) {
            return nameDiff;
        }

        // Deterministic tie-breaker for files with similar names.
        return b.path.localeCompare(a.path);
    });

const grouped = new Map<string, GroupedEntry[]>();
// Preserve sorted order within each category while grouping.
for (const entry of sortedEntries) {
    const folder = entry.path.split('/').at(-2)!;
    const list = grouped.get(folder) ?? [];
    list.push(entry);
    grouped.set(folder, list);
}

const images: OptimizedImage[] = await Promise.all(
    // Flatten categories in explicit display order while preserving per-category sort.
    CATEGORY_ORDER.flatMap(([folder, label]) =>
        [...(grouped.get(folder) ?? [])]
            .map(async ({ mod }) => {
            const img = mod.default;
            const optimized = await getImage({ src: img, format: "webp", width: 560 });
            return {
                src: optimized.src,
                width: (optimized.attributes.width as number) ?? img.width,
                height: (optimized.attributes.height as number) ?? img.height,
                originalSrc: img.src,
                category: label,
            };
            })
    )
);
---

<Layout title="Art">
    <main class="lg:col-span-10 lg:col-start-3 col-span-12 px-0 sm:px-6 lg:px-0 pt-6 lg:pt-8">
        <div class="mb-4 flex flex-wrap items-end gap-x-3 gap-y-2 px-4 sm:px-0 lg:pl-28">
            <p class="text-left text-5xl font-bold leading-none xl:text-nowrap">Art</p>
            <RssFeedButton />
        </div>
        <ArtMasonryGrid artEntries={images} client:only="react"/>
    </main>
</Layout>
