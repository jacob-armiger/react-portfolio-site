---
import ContactForm from "../components/ContactForm.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact">
    <main class="col-span-10 col-start-2 sm:col-span-8 sm:col-start-3 lg:col-start-4 lg:col-span-6 page-top px-4 lg:px-0">
        <p class="mb-4 text-left text-5xl font-bold">Contact Me</p>
        <p class="mb-10 text-base leading-relaxed opacity-70">
            Questions, commissions, or lesson inquiries are all welcome. Fill out the form below and I will get back to you.
        </p>

        <ContactForm subject="Website Contact" />
    </main>
</Layout>