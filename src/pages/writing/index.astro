---
// https://jankraus.net/2024/04/05/how-to-build-a-simple-photo-gallery-with-astro/
// https://markjames.dev/blog/dynamically-importing-images-astro
// https://vite.dev/guide/features.html#glob-import
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BlogCard from "../../components/BlogCard.astro";
import Layout from "../../layouts/Layout.astro";

const articles = (await getCollection("article")).sort(
    (a: CollectionEntry<"article">, b: CollectionEntry<"article">) => {
        return Date.parse(String(b.data.date)) - Date.parse(String(a.data.date));
    },
);
---

<Layout title="Writing">
    <main class="col-span-12 lg:col-start-4 lg:col-span-6 px-4 sm:px-6 lg:px-0 page-top">
        <div class="flex items-baseline justify-between border-primary pb-6 mb-4 dark:border-primary-dark">
            <p class="text-left text-5xl font-bold xl:text-nowrap">Articles</p>
            <div class="relative flex items-center">
                <span
                    id="rss-copied"
                    class="pointer-events-none absolute right-full mr-2 whitespace-nowrap rounded bg-primary px-2 py-1 text-xs text-secondary opacity-0 transition-opacity dark:bg-primary-dark dark:text-secondary-dark"
                >
                    Copied — paste into your RSS reader
                </span>
                <button
                    id="rss-btn"
                    aria-label="Copy RSS feed URL"
                    title="Copy RSS feed URL"
                    class="flex items-center gap-1.5 rounded border border-primary/30 px-2 py-1 text-xs opacity-60 transition-opacity hover:opacity-100 dark:border-primary-dark/30"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
                    </svg>
                    RSS
                </button>
            </div>
        </div>
        <script>
            const btn = document.getElementById('rss-btn')!;
            const msg = document.getElementById('rss-copied')!;
            const feedUrl = 'https://jacobldraws.vercel.app/writing/rss.xml';
            let timer: ReturnType<typeof setTimeout>;

            function showMsg(text: string) {
                msg.textContent = text;
                msg.style.opacity = '1';
                clearTimeout(timer);
                timer = setTimeout(() => { msg.style.opacity = '0'; }, 2500);
            }

            btn.addEventListener('click', () => {
                navigator.clipboard.writeText(feedUrl).then(() => {
                    showMsg('Copied — paste into your RSS reader');
                });
            });
        </script>

        <div class="grid gap-y-12 sm:grid-cols-2 sm:gap-6 sm:gap-y-8 lg:grid-cols-3">
            {articles.map((art) => <BlogCard art={art} />)}
        </div>
    </main>
</Layout>
