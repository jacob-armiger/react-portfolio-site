---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import BreakpointIndicator from "../components/BreakpointIndicator.astro";
import heroImage from "../assets/contact.png";
import Layout from "../layouts/Layout.astro";

const HERO_VARIANT_WIDTHS = [640, 760, 880, 920, 1140, 1320, 1520, 1760, 1840];
const HERO_SIZES = "(min-width: 1280px) 920px, (min-width: 768px) 880px, 760px";
const GALLERY_VARIANT_WIDTHS = [320, 480, 640, 768, 960];
const GALLERY_SIZES = "(min-width: 1024px) 28vw, (min-width: 640px) 50vw, 100vw";
const HERO_LINES = ["Contact me to get", "art lessons or", "commission work"];
const HERO_COPY_CLASS = "flex w-full flex-col items-end pr-2 lg:items-start";
const HERO_HEADING_CLASS =
    "font-playfair text-[2.7rem] leading-[1.08] tracking-[-0.07em] sm:text-[3.5rem] md:text-[4rem] lg:text-[74px] lg:text-nowrap lg:leading-normal";
const HERO_ACTION_CLASS =
    "relative mt-6 inline-flex min-h-16 min-w-36 items-center justify-center overflow-hidden rounded-[3px] px-6 py-8 font-sans text-sm font-semibold sm:mt-9 sm:min-h-28 sm:min-w-48 sm:px-8 sm:py-6 sm:text-base hover:bg-none hover:border hover:border-primary hover:text-primary"; 

const art_images: any = Object.values(
    import.meta.glob<ImageMetadata>("/src/assets/selectedWork/*", {
        eager: true,
        import: "default",
    }),
);
---

<Layout title="JacobLDraws">
    <BreakpointIndicator />
    <main class="col-span-12 overflow-hidden lg:col-span-10 lg:pr-4">
        <div class="flex w-full flex-col gap-4 sm:gap-6 lg:gap-12 ">

            <section class="hero-section relative pt-2 lg:pt-16">
                    <div class="relative">
                        <div
                            aria-hidden="true"
                            class:list={[HERO_COPY_CLASS, "pointer-events-none absolute inset-0 z-[-15]"]}>
                            <div class:list={[HERO_HEADING_CLASS, "text-secondary dark:text-secondary-dark"]}>
                                {HERO_LINES.map((line) => <span class="block">{line}</span>)}
                            </div>
                            <div class={HERO_ACTION_CLASS}>
                                <span
                                    class="absolute inset-0 bg-secondary dark:bg-secondary-dark"></span>
                                <span class="relative text-secondary dark:text-secondary-dark">Contact</span>
                            </div>
                        </div>

                        <div class={HERO_COPY_CLASS}>
                        <h1 class:list={[HERO_HEADING_CLASS, "text-white mix-blend-difference"]}>
                            {HERO_LINES.map((line) => <span class="block">{line}</span>)}
                        </h1>
                        <a
                            href="/contact"
                            class:list={[
                                HERO_ACTION_CLASS,
                                "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary dark:focus-visible:outline-primary-dark",
                            ]}>
                            <span
                                aria-hidden="true"
                                class="absolute inset-0 bg-white mix-blend-difference"></span>
                            <span class="relative text-white mix-blend-difference">Contact</span>
                        </a>
                        </div>
                    </div>

                    <!--
                        Astro defines each AVIF, WebP, and PNG variant here; the image service
                        generates and caches the files automatically. All three formats preserve
                        transparency. Keep HERO_SIZES aligned with the --hero-w breakpoints below,
                        and only expand HERO_VARIANT_WIDTHS when those widths leave this ladder.
                    -->
                    <Picture
                        src={heroImage}
                        alt="Person reclining beside a green office chair while using a telephone"
                        formats={["avif", "webp"]}
                        fallbackFormat="png"
                        widths={HERO_VARIANT_WIDTHS}
                        sizes={HERO_SIZES}
                        quality={80}
                        priority
                        class="hero-image absolute -z-10"
                    />
            </section>
            <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
                {
                    art_images.map((img: ImageMetadata) => (
                        <div>
                            <Picture
                                src={img}
                                alt="Selected work"
                                formats={["avif", "webp"]}
                                widths={GALLERY_VARIANT_WIDTHS}
                                sizes={GALLERY_SIZES}
                                quality={78}
                                width={268}
                                height={358}
                                loading="lazy"
                                decoding="async"
                                class="w-full object-cover sm:h-[38rem] lg:h-[28.5rem]"
                            />
                        </div>
                    ))
                }
            </div>
        </div>
    </main>
</Layout>

<style>
    /*
     * Hero section: min-height is normally a viewport-relative value, but
     * since the hero image is `position: absolute` it doesn't contribute
     * to the section's own height. On short viewports (e.g. iPhone SE),
     * a pure `vh` min-height can end up shorter than the image's actual
     * bottom edge, letting the image grid below overlap it. On very tall
     * narrow viewports (e.g. an iPad in portrait), `vh` alone can also
     * grow far past what's needed, pushing the grid too far away.
     * `clamp(floor, vh, ceiling)` keeps a `vh`-based feel for normal
     * screens while guaranteeing the section is always at least tall
     * enough to contain the image (floor) and never grows unreasonably
     * tall on portrait/tall-aspect screens (ceiling).
     *
     * clamp(MIN, PREFERRED, MAX) arguments:
     *   MIN       floor - smallest allowed min-height (prevents the
     *             image grid below from overlapping the hero image on
     *             short viewports).
     *   PREFERRED viewport-relative value (`vh`) used as long as it
     *             falls between MIN and MAX.
     *   MAX       ceiling - largest allowed min-height (prevents the
     *             section from growing too tall, and the grid below
     *             from sitting too far away, on tall/narrow viewports).
     */
    /* base (<640px) */
    .hero-section {
        min-height: clamp(600px, 89vh, 650px);
    }

    /* md (768px+) */
    @media (min-width: 768px) {
        .hero-section {
            min-height: clamp(780px, 90vh, 700px);
        }
    }

    /* lg (1024px+) */
    @media (min-width: 1024px) {
        .hero-section {
            min-height: clamp(800px, 92vh, 900px);
        }
    }

    /*
     * Hero image: freely positioned/sized per breakpoint via CSS custom
     * properties instead of a long Tailwind arbitrary-value class string.
     * To reposition or resize (including swapping in a different image
     * later), tune the custom properties below rather than the
     * `top` / `left` / `width` / `height` declarations themselves.
     *
     * Custom properties ("arguments"):
     *   --hero-top  (length, required) vertical offset of the image's
     *               top edge relative to the section (negative pulls it
     *               up above the section's own top edge).
     *   --hero-left (length, required) horizontal offset of the image's
     *               left edge relative to the section (negative pulls it
     *               left of the section's own left edge).
     *   --hero-w    (length, required) rendered width of the image.
     *   --hero-h    (length, optional, default: none -> `auto`) rendered
     *               height of the image. Leave unset to preserve the
     *               image's natural aspect ratio (undistorted). Set it
     *               only if you need an exact width+height box; the
     *               image will then be cropped via `object-fit: cover`
     *               instead of stretched/distorted.
     */
    .hero-image {
        /* base (<640px) */
        --hero-top: -75px;
        --hero-left: -300px;
        --hero-w: 700px;
        top: var(--hero-top);
        left: var(--hero-left);
        width: var(--hero-w);
        max-width: none; /* override Tailwind preflight's img{max-width:100%} */
        height: var(--hero-h, auto);
        object-fit: cover;
    }

    /* sm (640px+) */
    @media (min-width: 640px) {
        .hero-image {
            --hero-top: -60px;
            --hero-left: -180px;
        }
    }

    /* md (768px+) */
    @media (min-width: 768px) {
        .hero-image {
            --hero-top: -55px;
            --hero-left: -180px;
            --hero-w: 880px;
        }
    }

    /* lg (1024px+) */
    @media (min-width: 1024px) {
        .hero-image {
            --hero-top: -95px;
            --hero-left: 230.7px;
        }
    }

    /* xl (1280px+) */
    @media (min-width: 1280px) {
        .hero-image {
            --hero-top: -95px;
            --hero-left: 230.7px;
            --hero-w: 920px;
        }
    }
</style>
