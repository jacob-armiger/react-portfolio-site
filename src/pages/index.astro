---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";

const art_images: any = Object.values(
    import.meta.glob<ImageMetadata>("/src/assets/selectedWork/*", {
        eager: true,
        import: "default",
    }),
);
---

<Layout title="JacobLDraws">
    <main class="col-span-12 lg:col-span-10 lg:pr-4">
        <div class="relative">
            <div class="grid w-full grid-cols-12 gap-1 sm:gap-1 lg:auto-rows-[28.5rem]">
                <div
                    class="col-span-12 row-span-3 mb-2 h-[1400px] bg-cover bg-top md:bg-left-top lg:row-span-2 lg:mb-0 lg:h-auto"
                    style="background-image: url(/banner_image2.jpeg); background-position: left top; background-size: 110% auto;">
                    <div class="w-6/12 pl-4 pt-12 text-left text-secondary md:ml-8 sm:pt-16 lg:pt-16">
                        <p
                            class="hero-title [text-wrap:balance] text-secondary md:tracking-normal dark:text-primary-dark-bright">
                            <span class="hero-linebox">
                                <span class="hero-linebox-text">GET ART LESSONS OR COMMISSION WORK</span>
                            </span>
                        </p>
                        <a href="/contact">
                            <button
                                class="hover:text-gray mt-8 border-[1px] bg-secondary px-10 py-9 font-sans font-semibold tracking-[0.08em] text-primary hover:bg-primary hover:text-secondary sm:mt-8">
                                Contact
                            </button>
                        </a>
                    </div>
                </div>
                {
                    art_images.map((img: ImageMetadata) => (
                        <div class="col-span-12 sm:col-span-6 lg:col-span-4">
                            <Image
                                src={img.src}
                                alt="Most recent blog image"
                                width={268}
                                height={358}
                                class="w-full object-cover sm:h-[38rem] lg:h-[28.5rem]"
                            />
                        </div>
                    ))
                }
            </div>
        </div>
    </main>
</Layout>
