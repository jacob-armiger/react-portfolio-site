---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";

interface Slide {
    src: string | ImageMetadata;
    alt: string;
    caption?: string;
}

interface Props {
    images?: Slide[];
    image?: Slide;
    label?: string;
    className?: string;
    showCaptions?: boolean;
}

const {
    images,
    image,
    label = "Image carousel",
    className = "max-w-5xl",
    showCaptions = false,
} = Astro.props as Props;

const inputImages = [...(image ? [image] : []), ...(Array.isArray(images) ? images : [])];

if (inputImages.length === 0) {
    throw new Error("ImageCarousel requires at least one image.");
}

const isSingleImage = inputImages.length === 1;

const resolvedImages = await Promise.all(
    inputImages.map(async (img) => {
        const source = img.src;

        if (typeof source === "string") {
            return {
                src: source,
                thumbSrc: source,
                thumbWidth: undefined,
                thumbHeight: undefined,
                alt: img.alt,
                caption: img.caption ?? "",
            };
        }

        const targetWidth = isSingleImage ? 1400 : 700;
        const thumbWidth = Math.min(source.width, targetWidth);
        const thumbHeight = Math.round((source.height / source.width) * thumbWidth);
        const optimizedThumb = await getImage({
            src: source,
            width: thumbWidth,
            format: "webp",
            quality: 78,
        });

        return {
            src: source.src,
            thumbSrc: optimizedThumb.src,
            thumbWidth,
            thumbHeight,
            alt: img.alt,
            caption: img.caption ?? "",
        };
    }),
);
---

<section
    class={`not-prose my-8 mx-auto w-full ${className}`}
    aria-label={label}
    data-image-carousel
    data-carousel-single={isSingleImage ? "true" : "false"}>
    <div class="image-carousel-strip">
        {
            resolvedImages.map((image, index) => (
                <button
                    type="button"
                    class="image-carousel-thumb"
                    data-carousel-thumb
                    data-carousel-index={index}
                    data-carousel-src={image.src}
                    data-carousel-alt={image.alt}
                    data-carousel-caption-text={image.caption}
                    aria-label={`Open image ${index + 1} in larger view`}>
                    <img
                        src={image.thumbSrc}
                        alt={image.alt}
                        width={image.thumbWidth}
                        height={image.thumbHeight}
                        loading={index === 0 ? "eager" : "lazy"}
                        fetchpriority={index === 0 ? "high" : "auto"}
                        decoding="async"
                        class="image-carousel-thumb-image !m-0 block rounded-md"
                    />
                    {showCaptions && image.caption ? (
                        <span class="mt-2 block text-center text-sm text-primary dark:text-primary-dark">
                            {image.caption}
                        </span>
                    ) : null}
                </button>
            ))
        }
    </div>

</section>

<script is:inline>
    (() => {
        const init = () => {
            const roots = Array.from(document.querySelectorAll("[data-image-carousel]"));
            if (roots.length === 0) return;

            roots.forEach((root) => {
                if (!(root instanceof HTMLElement)) return;
                if (root.dataset.carouselInitialized === "true") return;
                root.dataset.carouselInitialized = "true";

                const thumbs = Array.from(root.querySelectorAll("[data-carousel-thumb]"));
                if (thumbs.length === 0) return;

                const srcs = thumbs.map((t) => t.getAttribute("data-carousel-src") || "");

                thumbs.forEach((thumb, i) => {
                    thumb.addEventListener("click", () => {
                        if (typeof window.openImageZoom === "function") {
                            window.openImageZoom(srcs[i], { srcs, startIndex: i });
                        }
                    });
                });
            });
        };

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", init);
        } else {
            init();
        }
    })();
</script>

<style is:inline>
    .image-carousel-strip {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        gap: 1rem;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 0.25rem;
        -webkit-overflow-scrolling: touch;
    }

    .image-carousel-thumb {
        flex: 0 0 auto;
        width: fit-content;
        max-width: 16.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow: hidden;
        border: 1px solid rgb(var(--color-primary) / 0.2);
        border-radius: 0.75rem;
        background: rgb(255 255 255 / 0.7);
        padding: 0.5rem;
        text-align: left;
        box-shadow: 0 8px 24px rgb(120 113 108 / 0.2);
        transition: none;
        cursor: pointer;
    }

    .image-carousel-thumb:focus-visible {
        outline: 2px solid rgb(var(--color-primary));
        outline-offset: 2px;
    }

    .image-carousel-thumb-image {
        width: auto !important;
        max-width: 100%;
        max-height: 30rem;
        height: auto;
    }

    [data-carousel-single="true"] .image-carousel-strip {
        display: block;
        text-align: center;
        overflow-x: visible;
    }

    [data-carousel-single="true"] .image-carousel-thumb {
        width: fit-content;
        max-width: 100%;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
    }

    [data-carousel-single="true"] .image-carousel-thumb img {
        width: auto !important;
        max-width: min(34rem, 100%);
        max-height: 66vh;
    }

    .image-carousel-strip::-webkit-scrollbar {
        height: 10px;
    }

    .image-carousel-strip::-webkit-scrollbar-thumb {
        border-radius: 9999px;
        background: rgb(120 113 108 / 0.4);
    }

    :global(html.dark) .image-carousel-thumb {
        border-color: rgb(var(--color-primary-dark) / 0.3);
        background: rgb(28 25 23 / 0.85);
    }
</style>
