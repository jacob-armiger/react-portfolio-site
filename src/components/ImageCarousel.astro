---
interface Slide {
    src: string | { src: string };
    alt: string;
    caption?: string;
}

interface Props {
    images?: Slide[];
    image?: Slide;
    label?: string;
    className?: string;
    showCaptions?: boolean;
}

const {
    images,
    image,
    label = "Image carousel",
    className = "max-w-5xl",
    showCaptions = false,
} = Astro.props as Props;

const inputImages = [...(image ? [image] : []), ...(Array.isArray(images) ? images : [])];

if (inputImages.length === 0) {
    throw new Error("ImageCarousel requires at least one image.");
}

const resolvedImages = inputImages.map((img) => ({
    src: typeof img.src === "string" ? img.src : img.src.src,
    alt: img.alt,
    caption: img.caption ?? "",
}));

const isSingleImage = resolvedImages.length === 1;
---

<section
    class={`not-prose my-8 mx-auto w-full ${className}`}
    aria-label={label}
    data-image-carousel
    data-carousel-single={isSingleImage ? "true" : "false"}>
    <div class="image-carousel-strip">
        {
            resolvedImages.map((image, index) => (
                <button
                    type="button"
                    class="image-carousel-thumb"
                    data-carousel-thumb
                    data-carousel-index={index}
                    data-carousel-src={image.src}
                    data-carousel-alt={image.alt}
                    data-carousel-caption-text={image.caption}
                    aria-label={`Open image ${index + 1} in larger view`}>
                    <img
                        src={image.src}
                        alt={image.alt}
                        loading={index < 2 ? "eager" : "lazy"}
                        decoding="async"
                        class="image-carousel-thumb-image !m-0 block rounded-md"
                    />
                    {showCaptions && image.caption ? (
                        <span class="mt-2 block text-center text-sm text-primary dark:text-primary-dark">
                            {image.caption}
                        </span>
                    ) : null}
                </button>
            ))
        }
    </div>

    <dialog class="image-lightbox" data-carousel-dialog aria-label={`${label} expanded view`}>
        <div class="image-lightbox__inner">
            <button type="button" class="image-lightbox__close" data-carousel-close aria-label="Close larger view">
                Close
            </button>

            <img
                src=""
                alt=""
                class="image-lightbox__image"
                style="width:auto;max-width:96vw;max-height:92vh;height:auto;object-fit:contain;"
                data-carousel-image
                loading="eager"
                decoding="async"
            />

            {showCaptions ? <p class="image-lightbox__caption" data-carousel-modal-caption></p> : null}
        </div>
    </dialog>
</section>

<script is:inline>
    (() => {
        const roots = Array.from(document.querySelectorAll("[data-image-carousel]"));
        if (roots.length === 0) return;

        roots.forEach((root) => {
            if (!(root instanceof HTMLElement)) return;
            if (root.dataset.carouselInitialized === "true") return;
            root.dataset.carouselInitialized = "true";

            const dialog = root.querySelector("[data-carousel-dialog]");
            const modalImage = root.querySelector("[data-carousel-image]");
            const modalCaption = root.querySelector("[data-carousel-modal-caption]");
            const closeButton = root.querySelector("[data-carousel-close]");
            const thumbs = Array.from(root.querySelectorAll("[data-carousel-thumb]"));

            if (!(dialog instanceof HTMLDialogElement) || !(modalImage instanceof HTMLImageElement) || thumbs.length === 0) {
                return;
            }

            const openImage = (thumb) => {
                const src = thumb.getAttribute("data-carousel-src") || "";
                const alt = thumb.getAttribute("data-carousel-alt") || "";
                const caption = thumb.getAttribute("data-carousel-caption-text") || "";

                modalImage.src = src;
                modalImage.alt = alt;

                if (modalCaption instanceof HTMLElement) {
                    modalCaption.textContent = caption;
                }

                if (!dialog.open) {
                    dialog.showModal();
                    document.body.classList.add("overflow-hidden");
                }
            };

            thumbs.forEach((thumb) => {
                thumb.addEventListener("click", () => openImage(thumb));
            });

            closeButton?.addEventListener("click", () => {
                if (dialog.open) {
                    dialog.close();
                }
            });

            dialog.addEventListener("close", () => {
                document.body.classList.remove("overflow-hidden");
            });

            dialog.addEventListener("click", (event) => {
                const target = event.target;
                if (!(target instanceof Node)) return;

                if (target === modalImage) return;
                if (closeButton instanceof HTMLElement && closeButton.contains(target)) return;

                if (dialog.open) {
                    dialog.close();
                }
            });
        });
    })();
</script>

<style is:inline>
    .image-carousel-strip {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        gap: 1rem;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 0.25rem;
        -webkit-overflow-scrolling: touch;
    }

    .image-carousel-thumb {
        flex: 0 0 auto;
        width: fit-content;
        max-width: 16.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow: hidden;
        border: 1px solid rgb(var(--color-primary) / 0.2);
        border-radius: 0.75rem;
        background: rgb(255 255 255 / 0.7);
        padding: 0.5rem;
        text-align: left;
        box-shadow: 0 8px 24px rgb(120 113 108 / 0.2);
        transition: none;
    }

    .image-carousel-thumb:focus-visible {
        outline: 2px solid rgb(var(--color-primary));
        outline-offset: 2px;
    }

    .image-carousel-thumb-image {
        width: auto !important;
        max-width: 100%;
        max-height: 30rem;
        height: auto;
    }

    [data-carousel-single="true"] .image-carousel-strip {
        display: block;
        text-align: center;
        overflow-x: visible;
    }

    [data-carousel-single="true"] .image-carousel-thumb {
        width: fit-content;
        max-width: 100%;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
    }

    [data-carousel-single="true"] .image-carousel-thumb img {
        width: auto !important;
        max-width: min(34rem, 100%);
        max-height: 66vh;
    }

    .image-carousel-strip::-webkit-scrollbar {
        height: 10px;
    }

    .image-carousel-strip::-webkit-scrollbar-thumb {
        border-radius: 9999px;
        background: rgb(120 113 108 / 0.4);
    }

    .image-lightbox {
        border: none;
        padding: 0;
        background: transparent;
        width: min(96vw, 1700px);
        max-width: 96vw;
    }

    .image-lightbox::backdrop {
        background: rgb(0 0 0 / 0.82);
    }

    .image-lightbox__inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .image-lightbox__image {
        display: block;
        width: auto;
        max-width: 96vw;
        max-height: 92vh;
        height: auto;
        border-radius: 0.5rem;
    }

    .image-lightbox__caption {
        margin: 0.75rem 0 0;
        text-align: center;
        color: rgb(255 255 255 / 0.95);
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .image-lightbox__close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        z-index: 1;
        border: 1px solid rgb(255 255 255 / 0.7);
        border-radius: 9999px;
        background: rgb(0 0 0 / 0.45);
        padding: 0.25rem 0.75rem;
        color: white;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1;
    }

    .image-lightbox__close:hover {
        background: rgb(255 255 255 / 0.14);
    }

    :global(html.dark) .image-carousel-thumb {
        border-color: rgb(var(--color-primary-dark) / 0.3);
        background: rgb(28 25 23 / 0.85);
    }
</style>
